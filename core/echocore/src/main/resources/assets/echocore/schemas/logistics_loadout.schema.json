{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://echo/echocore/logistics_loadout.schema.json",
  "title": "ECHO Logistics Loadout Preset",
  "description": "Factory / logistics loadout preset for EchoLogisticsNetwork.",
  "type": "object",
  "required": ["title", "requirements"],
  "properties": {
    "id": { "type": "string", "description": "Loadout identifier. Inferred from file path if omitted." },
    "title": { "type": "string" },
    "order": { "type": "integer", "default": 0 },
    "icon": { "type": "string", "default": "minecraft:chest" },
    "requirements": {
      "type": "array",
      "description": "At least one requirement is required.",
      "items": {
        "type": "object",
        "properties": {
          "item": { "type": "string", "description": "Item identifier (exactly one of item/tag/category)." },
          "tag": { "type": "string", "description": "Item tag identifier." },
          "category": { "type": "string", "description": "Supply category identifier." },
          "count": { "type": "integer", "default": 1, "minimum": 1 },
          "optional": { "type": "boolean", "default": false }
        },
        "additionalProperties": true
      }
    },
    "targetBlockTypes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Block identifiers this loadout can target."
    },
    "deliveryTicks": { "type": "integer", "default": 160, "minimum": 0 },
    "factoryTaskId": { "type": "string", "description": "Optional multiblock task identifier for restocking." },
    "restockTargetRuns": { "type": "integer", "default": 3 },
    "restockMinRuns": { "type": "integer", "default": 1 },
    "restockMaxInFlight": { "type": "integer", "default": 1 },
    "restockCooldownTicks": { "type": "integer", "default": 200 }
  },
  "additionalProperties": true
}
