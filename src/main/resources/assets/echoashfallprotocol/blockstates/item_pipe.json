{
  "multipart": [
    {
      "apply": { "model": "echoashfallprotocol:block/item_pipe_core" }
    },
    {
      "when": { "north": true },
      "apply": { "model": "echoashfallprotocol:block/item_pipe_connection", "uvlock": true }
    },
    {
      "when": { "south": true },
      "apply": { "model": "echoashfallprotocol:block/item_pipe_connection", "y": 180, "uvlock": true }
    },
    {
      "when": { "east": true },
      "apply": { "model": "echoashfallprotocol:block/item_pipe_connection", "y": 90, "uvlock": true }
    },
    {
      "when": { "west": true },
      "apply": { "model": "echoashfallprotocol:block/item_pipe_connection", "y": 270, "uvlock": true }
    },
    {
      "when": { "up": true },
      "apply": { "model": "echoashfallprotocol:block/item_pipe_connection", "x": 270, "uvlock": true }
    },
    {
      "when": { "down": true },
      "apply": { "model": "echoashfallprotocol:block/item_pipe_connection", "x": 90, "uvlock": true }
    }
  ]
}
