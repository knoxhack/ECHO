{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ECHO Recovery Rule",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "dimension": { "type": "string" },
    "region": {
      "type": "object",
      "properties": {
        "min": { "type": "array", "items": { "type": "integer" } },
        "max": { "type": "array", "items": { "type": "integer" } }
      }
    },
    "action": {
      "type": "string",
      "enum": ["redirect_to_nearest_safe", "redirect_to_spawn", "allow", "deny"]
    },
    "fallback_pos": { "type": "array", "items": { "type": "integer" } }
  },
  "required": ["id", "action"]
}
