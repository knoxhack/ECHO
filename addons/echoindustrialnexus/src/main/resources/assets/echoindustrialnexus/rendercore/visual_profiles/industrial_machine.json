{
  "schema_version": 5,
  "base_texture": "echoindustrialnexus:textures/block/machine_casing.png",
  "animation_profile": "echoindustrialnexus:industrial_machine",
  "particle_profile": "echoindustrialnexus:industrial_machine",
  "default_state": "IDLE",
  "transition_seconds": 0.2,
  "materials": {
    "cyan_emissive": {
      "color": "#FF66E8FF",
      "alpha": 0.9,
      "emissive": true,
      "blend_mode": "additive"
    },
    "warning_emissive": {
      "color": "#FFFF7A28",
      "alpha": 0.85,
      "emissive": true,
      "blend_mode": "additive"
    },
    "corrupt_emissive": {
      "color": "#FFB64DFF",
      "alpha": 0.9,
      "emissive": true,
      "blend_mode": "additive"
    }
  },
  "layers": [
    {
      "id": "online_flux_glow",
      "kind": "glow",
      "texture": "echoindustrialnexus:textures/block/factory_light.png",
      "material": "cyan_emissive",
      "states": ["ONLINE", "ACTIVE", "WORKING", "CHARGING", "COMPLETE"],
      "parts": ["core", "screen", "output_face", "active_core"]
    },
    {
      "id": "thermal_warning",
      "kind": "overlay",
      "texture": "echoindustrialnexus:textures/block/emergency_light.png",
      "material": "warning_emissive",
      "states": ["OVERHEATED", "FAILED"],
      "parts": ["vent_left", "vent_right", "exhaust_top"]
    },
    {
      "id": "nexus_corruption",
      "kind": "overlay",
      "texture": "echoindustrialnexus:textures/block/nexus_thermal_injector.png",
      "material": "corrupt_emissive",
      "states": ["CORRUPTED"],
      "parts": ["core", "screen", "vent_left", "vent_right"]
    }
  ],
  "state_animations": {
    "ONLINE": "machine_idle",
    "ACTIVE": "machine_active",
    "WORKING": "machine_active",
    "CHARGING": "machine_charge",
    "OVERHEATED": "thermal_warning",
    "FAILED": "thermal_warning",
    "CORRUPTED": "corrupt_flicker"
  },
  "anchors": {
    "core": { "offset": [0.0, 0.62, 0.0] },
    "screen": { "offset": [0.0, 0.72, -0.53] },
    "vent_left": { "offset": [-0.42, 0.42, 0.0] },
    "vent_right": { "offset": [0.42, 0.42, 0.0] },
    "exhaust_top": { "offset": [0.0, 1.05, 0.0] },
    "output_face": { "offset": [0.0, 0.45, 0.56] }
  },
  "block_parts": {
    "core": {
      "directions": ["north", "south", "east", "west", "up"],
      "ambient_occlusion": true
    },
    "active_core": {
      "directions": ["north", "south", "east", "west", "up"],
      "ambient_occlusion": true,
      "block_state": { "active": "true" }
    },
    "screen": {
      "directions": ["north"],
      "ambient_occlusion": true
    },
    "vent_left": {
      "directions": ["west"],
      "ambient_occlusion": true
    },
    "vent_right": {
      "directions": ["east"],
      "ambient_occlusion": true
    },
    "vents": {
      "directions": ["east", "west"],
      "ambient_occlusion": true
    },
    "exhaust_top": {
      "directions": ["up"]
    },
    "output_face": {
      "directions": ["south"],
      "ambient_occlusion": true
    }
  }
}
