{
  "name": "noxhack-modpack-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "server:dev": "tsx watch src/server/index.ts",
    "client:dev": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.json --noEmit && vite build",
    "preview": "node dist-server/index.js",
    "test": "node --import tsx --test tests/*.test.mjs",
    "self-check": "node scripts/self-check.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
